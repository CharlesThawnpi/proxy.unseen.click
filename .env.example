# UNSEEN PROXY — environment template (PLACEHOLDERS ONLY)
# ----------------------------------------------------------------------------
# This file is the single annotated reference for every secret/config the
# Master needs. It is the ONLY env file tracked in git (IMPLEMENTATION_PLAN.md
# §31A.2). Real values live in `.env` on the Master ONLY — `.env` is git-ignored
# and must be 0600, root-owned (§31 rule 9).
#
# Per-service `.env` files are derived from this master template when each
# service is built (see docs/DEPLOYMENT.md). Never replace __PLACEHOLDER__ in
# THIS file — copy it to `.env` and fill real values there.
# ----------------------------------------------------------------------------

# === Core / shared ==========================================================
# Path to the single SQLite database (created by the migration runner, Phase 4).
DB_PATH=/opt/unseen-proxy/data/unseenproxy.sqlite3
LOG_LEVEL=info
ENVIRONMENT=development            # development | staging | production

# Backup-critical: encrypts durable subscription tokens at rest (§31 rule 2).
# Losing this means no token can be decrypted — back it up WITH the DB (§30.3).
ACCESS_TOKEN_ENCRYPTION_SECRET=__PLACEHOLDER__

# === Telegram bot (Phase 5) =================================================
TELEGRAM_BOT_TOKEN=__PLACEHOLDER__            # e.g. replace_me (dry-run in Phase 5; never sent)
ADMIN_TELEGRAM_IDS=__PLACEHOLDER__            # comma-separated admin Telegram ids, e.g. 123456789,987654321
TELEGRAM_ADMIN_IDS=__PLACEHOLDER__            # legacy alias (read as fallback); prefer ADMIN_TELEGRAM_IDS

# === Service binds (loopback only; nginx terminates TLS — §5, §8) ===========
SIDECAR_BIND=127.0.0.1:8197                   # sub.unseen.click  -> /s/<token>
ADMIN_BIND=127.0.0.1:8190                     # panel.unseen.click
PORTAL_BIND=127.0.0.1:8191                    # app.unseen.click
API_BIND=127.0.0.1:8192                       # api.unseen.click

# === Hiddify nodes (Phase 2+; nodes are DATA — §6.1) ========================
# Referenced by handle from the proxy_nodes table; secrets live here only.
# Panel API base + a least-privilege service API key per node.
NODE_DE_PANEL_API_BASE=__PLACEHOLDER__
NODE_DE_API_KEY=__PLACEHOLDER__
NODE_SG1_PANEL_API_BASE=__PLACEHOLDER__
NODE_SG1_API_KEY=__PLACEHOLDER__
NODE_SG2_PANEL_API_BASE=__PLACEHOLDER__
NODE_SG2_API_KEY=__PLACEHOLDER__
NODE_US_PANEL_API_BASE=__PLACEHOLDER__
NODE_US_API_KEY=__PLACEHOLDER__

# === Live-action latches (dry-run is the default everywhere — Appendix D) ===
# Live mutations require BOTH the env latch true AND a `--live --confirm` flag.
ALLOW_LIVE_PROVISIONING=false
ALLOW_LIVE_BOT_SENDS=false
ALLOW_REAL_PAYMENTS=false

# === Source control / deploy (§31A.5) =======================================
# The read-only deploy key's PRIVATE half lives on the Master only, never here
# and never in git. This template only records that it is expected.
DEPLOY_KEY_PATH=/root/.ssh/unseenproxy_deploy_ed25519
