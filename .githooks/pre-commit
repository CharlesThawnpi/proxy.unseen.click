#!/usr/bin/env bash
# UNSEEN PROXY pre-commit hook (tracked; enabled via `git config core.hooksPath .githooks`).
# Delegates to the secret scanner. See docs/VERSION_CONTROL.md and IMPLEMENTATION_PLAN.md §31A.3.
set -euo pipefail
repo_root="$(git rev-parse --show-toplevel)"
exec bash "$repo_root/scripts/pre-commit-secret-scan.sh"
